# Copy to `infra/.env` and fill in real values. Never commit the real .env.
# Loaded by docker compose via `--env-file infra/.env`.

# ── Telegram ───────────────────────────────────────────────────────────────
BOT_USERNAME=Bot
BOT_TOKEN=Token
BOT_NAME=Lebowski
BOT_LANGUAGE=French

# ── Google Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=key

# ── Bot Config ─────────────────────────────────────────────────────────────
# If BOT_AI_TRIGGER_CHAT_ID is empty, the bot uses the last chat that sent it a
# message after startup. Durations use Spring Boot format, e.g. 45m, 3h, 30s.
BOT_AI_TRIGGER_ENABLED=true
BOT_AI_TRIGGER_CHAT_ID=111
BOT_AI_TRIGGER_HISTORY_WINDOW=3h
BOT_AI_TRIGGER_MIN_DELAY=2h
BOT_AI_TRIGGER_MAX_DELAY=4h
BOT_AI_TRIGGER_MAX_HISTORY_MESSAGES=100
BOT_AI_TRIGGER_TIME_ZONE=Europe/Kyiv
BOT_AI_TRIGGER_IDLE_PARTICIPATION_THRESHOLD=2h
BOT_ASSISTANT_RETRY_BACKOFF=1s
BOT_ASSISTANT_PERSONA_PROMPT=You are Liza, a long-time member of this group chat. Be concise, sharp, useful, and adapt to the room.

# ── Postgres (only used inside the docker network) ─────────────────────────
DB_NAME=botdb
DB_USER=bot
DB_PASSWORD=bot_password

# ── JVM tuning (optional) ──────────────────────────────────────────────────
JAVA_OPTS=-Xms256m -Xmx512m

